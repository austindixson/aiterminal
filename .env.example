# Copy to .env in the project root. Never commit .env.

# Required for AI features (chat, agent, daemon). Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=

# Comma-separated absolute directories the app may read/write via file IPC.
# Defaults to the current working directory only if unset.
# AITERMINAL_WORKSPACE_ROOTS=/path/to/repo,/another/path

# Max file size in bytes for read/write (default 10485760)
# AITERMINAL_MAX_FILE_BYTES=10485760

# --- Local ecosystem (optional) ---
# lossless-claude: persist AI chat to the same SQLite recall DB as Claude Code
# AITERMINAL_LOSSLESS_ROOT=/Users/ghost/Desktop/lossless-claude

# dietmcp (~/.local/bin/dietmcp if installed)
# AITERMINAL_DIETMCP_BIN=dietmcp

# ferroclaw single binary (optional passthrough: ferroclaw exec "goal")
# AITERMINAL_FERROCLAW_BIN=/path/to/ferroclaw

# skinnytools: CLI path OR python module (default: python3 -m skinnytools)
# AITERMINAL_SKINNYTOOLS_BIN=
# AITERMINAL_SKINNYTOOLS_PYTHON=python3
# AITERMINAL_SKINNYTOOLS_MODULE=skinnytools

# Extra env file merged after .env (superenv-style secrets)
# AITERMINAL_SUPERENV_FILE=/path/to/extra.env

# --- Kokoro-82M TTS (optional; replaces speechSynthesis when enabled) ---
# macOS: brew install espeak-ng
# Recommended: python3 -m venv .venv-kokoro && .venv-kokoro/bin/pip install -r scripts/requirements-kokoro.txt
# (PEP 668 blocks system pip; requirements include en_core_web_sm for misaki/spaCy.)
# AITERMINAL_KOKORO=1
# AITERMINAL_KOKORO_PYTHON=/absolute/path/to/aiterminal/.venv-kokoro/bin/python3
# AITERMINAL_KOKORO_SCRIPT=/absolute/path/to/kokoro-tts-stdio.py
# AITERMINAL_KOKORO_LANG=a
# AITERMINAL_KOKORO_VOICE=af_heart
